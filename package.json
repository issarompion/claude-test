{
  "name": "hello-world",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=verbose",
    "typecheck": "tsc --noEmit",
    "api:dev": "npm --prefix api run dev",
    "api:test": "npm --prefix api test",
    "api:typecheck": "npm --prefix api run typecheck",
    "dev:all": "concurrently --names \"front,api\" --prefix-colors \"cyan,green\" \"npm run dev\" \"npm run api:dev\"",
    "test:all": "npm test && npm run api:test"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^10.0.3",
    "jsdom": "^24.1.1",
    "typescript": "^5.5.3",
    "vite": "^6.4.3",
    "vitest": "^4.1.9"
  }
}
