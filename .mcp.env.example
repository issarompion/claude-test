# MCP Servers - Environment variables
# Copy this file to .env and fill in the values
# Enable servers in .mcp.json ("enabled": true)

# GitHub MCP (gh auth status to verify)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# PostgreSQL MCP
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Slack MCP (recommended by Boris Cherny)
# SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx
# SLACK_TEAM_ID=T00000000

# Sentry MCP (recommended by Boris Cherny)
# SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxx
# SENTRY_ORG=your-org

# BigQuery MCP (recommended by Boris Cherny)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# BIGQUERY_PROJECT_ID=your-project-id

# Linear MCP
# LINEAR_API_KEY=lin_api_xxxxxxxxxxxx

# Notion MCP
# NOTION_API_KEY=ntn_xxxxxxxxxxxx
