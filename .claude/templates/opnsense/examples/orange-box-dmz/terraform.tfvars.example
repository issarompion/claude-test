# =============================================================================
# Example configuration - COPY to terraform.tfvars
# =============================================================================
# DO NOT COMMIT terraform.tfvars (contains secrets)
# =============================================================================

# -----------------------------------------------------------------------------
# OPNsense API connection
# -----------------------------------------------------------------------------

opnsense_uri           = "https://192.168.10.1"
opnsense_api_key       = "your-api-key"
opnsense_api_secret    = "your-api-secret"
opnsense_allow_insecure = true  # Self-signed certificate

# -----------------------------------------------------------------------------
# Interfaces (adapt to your VM configuration)
# -----------------------------------------------------------------------------

wan_interface = "vtnet0"  # Interface connected to the Orange box
lan_interface = "vtnet1"  # Interface connected to the local network

# -----------------------------------------------------------------------------
# LAN network
# -----------------------------------------------------------------------------

lan_ip           = "192.168.10.1"
lan_subnet       = 24
lan_network_base = "192.168.10.0"

# -----------------------------------------------------------------------------
# Firewall
# -----------------------------------------------------------------------------

log_blocked_traffic = true

# -----------------------------------------------------------------------------
# Port Forwarding (optional)
# -----------------------------------------------------------------------------
# Leave empty ("") to disable

# Internal web server
web_server_ip = ""  # e.g.: "192.168.10.20"

# Internal SSH server
ssh_server_ip     = ""    # e.g.: "192.168.10.10"
ssh_external_port = "2222"  # Non-standard port recommended
